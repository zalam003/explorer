#
# Set to prod or dev
MIX_ENV=prod
#MIX_ENV=dev

# Set version
BLOCKSCOUT_VERSION=v3.7.0

# Maintenance Message
SHOW_MAINTENANCE_ALERT=false
MAINTENANCE_ALERT_MESSAGE="Test Energi Explorer"

# wobserver interface
WOBSERVER_ENABLED=false

# Default (in seconds): 60 * 60 * 24 * 2
TOKEN_METADATA_UPDATE_INTERVAL=86400

#
BLOCKSCOUT_PROTOCOL=https
BLOCK_TRANSFORMER=base
#GAS_PRICE=11
ETHEREUM_JSONRPC_TRANSPORT=http
ETHEREUM_JSONRPC_MAXCONN=100
ETHEREUM_JSONRPC_HTTP_URL=http://172.31.77.121:39796
ETHEREUM_JSONRPC_WS_URL=ws://172.31.77.121:39795
ETHEREUM_JSONRPC_TRACE_URL=$ETHEREUM_JSONRPC_HTTP_URL
COIN=NRG
ENABLE_TXS_STATS=true
SHOW_TXS_CHART=true
ALLOWED_EVM_VERSIONS=petersburg
ETHEREUM_JSONRPC_VARIANT=geth
COINGECKO_COIN_ID=energi
NETWORK=Energi
SUBNETWORK=Mainnet
CHAIN_ID=39797
EMISSION_FORMAT=MNRG
#FIRST_BLOCK=505118
MAX_SKIPPING_DISTANCE=2
CHECK_ORIGIN=true
CHAIN_SPEC_PATH=chain_spec_energi_mainnet.json
PORT=4000
