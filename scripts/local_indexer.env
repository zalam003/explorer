#
# Set to prod or dev
MIX_ENV=prod
#MIX_ENV=dev

# Set version
BLOCKSCOUT_VERSION=v5.2.3

# Maintenance Message
SHOW_MAINTENANCE_ALERT=false
MAINTENANCE_ALERT_MESSAGE="Test Energi Explorer"

# wobserver interface
WOBSERVER_ENABLED=false

#
DISABLE_WEBAPP=false
DISABLE_INDEXER=false
API_V1_READ_METHODS_DISABLED=false
API_V1_WRITE_METHODS_DISABLED=false

# Default (in seconds): 60 * 60 * 24 * 2
TOKEN_METADATA_UPDATE_INTERVAL=86400

#
BLOCKSCOUT_PROTOCOL=http
BLOCKSCOUT_HOST=mainnet.energi.cloudns.cl:4000
BLOCK_TRANSFORMER=base
#GAS_PRICE=11

#
ETHEREUM_JSONRPC_TRANSPORT=http
ETHEREUM_JSONRPC_MAXCONN=50
ETHEREUM_JSONRPC_HTTP_URL=http://127.0.0.1:39796
ETHEREUM_JSONRPC_WS_URL=ws://127.0.0.1:39795
ETHEREUM_JSONRPC_TRACE_URL=$ETHEREUM_JSONRPC_HTTP_URL
ETHEREUM_JSONRPC_VARIANT=geth
API_RATE_LIMIT=88
ALLOWED_EVM_VERSIONS=petersburg,homestead,tangerineWhistle,spuriousDragon,byzantium,constantinople,istanbul
COIN=NRG
ENABLE_TXS_STATS=true
SHOW_TXS_CHART=true
COINGECKO_COIN_ID=energi
NETWORK=Energi
SUBNETWORK=Mainnet
CHAIN_ID=39797
EMISSION_FORMAT=MNRG
#FIRST_BLOCK=505118
FIRST_BLOCK=2
#MAX_SKIPPING_DISTANCE=2
CHECK_ORIGIN=true
CHAIN_SPEC_PATH=chain_spec_energi_mainnet.json
ENERGISWAP_API_URL=https://api.energiswap.exchange/v1
TOKEN_EXCHANGE_RATE_CACHE_PERIOD=300
WNRG_TOKEN_ADDRESS=0xA55F26319462355474A9F2c8790860776a329aA4
DISPLAY_TOKEN_ICONS=true
ENERGISWAP_AUTH_SECRET=
PORT=4000
JSON_RPC=https://nodeapi.energi.network/v1/jsonrpc

# DB Parameters
POOL_SIZE=50
PGHOST="127.0.0.1"
PGPORT=5432
PGDATABASE=explorer_mainnet_db
PGUSER=explorer_mainnet_db
PGPASSWORD=Block6scout123
